<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="top|center_horizontal"
    android:padding="24dp"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <!-- Device Icon -->
    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="24dp"
        android:contentDescription="Tracked Device Icon"
        android:src="@android:drawable/ic_secure"
        app:tint="#1976D2" />

    <!-- Device Name -->
    <TextView
        android:id="@+id/tvDetailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Device Name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#212121"
        tools:text="Smart Tag" />

    <!-- MAC Address -->
    <TextView
        android:id="@+id/tvDetailMac"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="MAC: --:--:--:--"
        android:textSize="14sp"
        android:textColor="#757575"
        tools:text="MAC: 00:1A:7D:DA:71:13" />

    <!-- Ring Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRingDevice"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:text="Ring Tag (Buzzer)"
        android:textColor="@android:color/black"
        android:backgroundTint="#FFB300"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_lock_idle_alarm"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />

    <!-- Battery Status -->
    <TextView
        android:id="@+id/tvBatteryDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="🔋 Battery: --"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        tools:text="🔋 Battery: 85%" />

    <!-- Open Maps Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenMaps"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:text="Find in Google Maps"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_dialog_map"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />

    <!-- Flexible Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Unpair Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUnpair"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:text="Unpair Device"
        android:textColor="#D32F2F"
        app:strokeColor="#D32F2F"
        app:cornerRadius="12dp" />

</LinearLayout>